import re\
\
class CitationEngine:\
    """\
    Core logic for identifying South African legal citations.\
    Designed for use in the 'Citation Checker App' MVP.\
    """\
    \
    # South African Citation Patterns\
    PATTERNS = \{\
        # Standard: Case Name 1995 (3) SA 391 (CC)\
        "standard_sa": r"([A-Z].+?v\\s.+?)\\s(\\d\{4\})\\s\\((\\d+)\\)\\sSA\\s(\\d+)\\s\\(([A-Z]+)\\)",\
        \
        # Neutral: Case Name [2023] ZASCA 15\
        "neutral_zasca": r"([A-Z].+?v\\s.+?)\\s\\[(\\d\{4\})\\]\\sZASCA\\s(\\d+)",\
        \
        # Constitutional Court: [2022] ZACC 45\
        "neutral_zacc": r"([A-Z].+?v\\s.+?)\\s\\[(\\d\{4\})\\]\\sZACC\\s(\\d+)",\
        \
        # Regional: [2023] ZAWCHC 12\
        "neutral_regional": r"([A-Z].+?v\\s.+?)\\s\\[(\\d\{4\})\\]\\sZA[A-Z]\{3,4\}\\s(\\d+)"\
    \}\
\
    def extract_citations(self, text):\
        found_citations = []\
        for label, pattern in self.PATTERNS.items():\
            matches = re.findall(pattern, text)\
            for m in matches:\
                found_citations.append(\{"type": label, "data": m\})\
        return found_citations\
\
